# ====================================================
# WhatsApp AI Agent Kit — Variables de Entorno
# ====================================================
# Copia este fichero como .env.local y completa los valores.
# NUNCA subas .env.local al repositorio.

# --------------------------------------------------
# OBLIGATORIA: API Key de OpenRouter
# Formato: sk-or-v1-...
# Obtén la tuya en: https://openrouter.ai/keys
# El bot NO arranca si esta variable está vacía.
# --------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --------------------------------------------------
# Modelo de IA (con default)
# NUNCA usar modelos con sufijo :free — se saturan
# y devuelven error 429 en producción.
#
# Recomendados:
#   openai/gpt-4o-mini         (relación calidad/precio)
#   anthropic/claude-haiku-4-5 (rápido y preciso)
#   google/gemini-2.5-flash    (muy capaz y barato)
# --------------------------------------------------
OPENROUTER_MODEL=openai/gpt-4o-mini

# --------------------------------------------------
# OPCIONAL: Webhook de Google Apps Script para leads
# Si vacío, la tool guardarLead queda inactiva.
# Ejemplo: https://script.google.com/macros/s/AKfy.../exec
# --------------------------------------------------
GOOGLE_SHEETS_WEBHOOK_URL=

# --------------------------------------------------
# OPCIONAL: URL de Cal.com o Calendly para agendar
# Si vacío, la tool agendar queda inactiva.
# Ejemplo: https://cal.com/tu-usuario/diagnostico
# --------------------------------------------------
CAL_BOOKING_URL=

# --------------------------------------------------
# OPCIONAL: Puerto del dashboard Next.js (default 3000)
# --------------------------------------------------
PORT=3000

# --------------------------------------------------
# OPCIONAL: Nivel de log del bot (default info)
# Opciones: silent | error | warn | info | debug
# --------------------------------------------------
LOG_LEVEL=info
